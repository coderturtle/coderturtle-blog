---
import Layout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const workshops = (await getCollection("workshops")).sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  if (a.data.order !== b.data.order) return a.data.order - b.data.order;
  const aDate = a.data.updatedDate ?? a.data.startDate;
  const bDate = b.data.updatedDate ?? b.data.startDate;
  return bDate.getTime() - aDate.getTime();
});

const allTags = [...new Set(workshops.flatMap((w) => w.data.tags))].sort();
---

<Layout
  title="Workshops"
  description="Self-paced workshops for people who already drive a coding agent daily: real gates, real build logs, no highlight reel."
>
  <section class="flex flex-col items-center gap-4 pb-12 pt-8 text-center md:pb-16">
    <p class="eyebrow">Learn by building, with your own agent</p>
    <h1 class="max-w-3xl text-4xl font-bold leading-tight md:text-6xl">Workshops, not tutorials.</h1>
    <p class="lede max-w-2xl">
      Every workshop here is self-paced and gated: a real artifact you build with your
      own coding-agent harness, checked against a rubric or a deterministic test, no
      "read this, then move on." Each one is its own repo, its own site, and its own
      honest build log.
    </p>
  </section>

  {allTags.length > 0 && (
    <div class="tag-filter-bar" role="group" aria-label="Filter workshops by tag">
      <button type="button" class="tag-filter-btn is-active" data-tag="all" aria-pressed="true">
        All
      </button>
      {allTags.map((tag) => (
        <button type="button" class="tag-filter-btn" data-tag={tag} aria-pressed="false">
          {tag}
        </button>
      ))}
    </div>
  )}

  <div class="note-grid log-grid" id="workshop-grid">
    {workshops.length > 0 ? workshops.map((workshop) => (
      <article class="note-card" data-tags={workshop.data.tags.join(",")}>
        <span class={`status-pill status-${workshop.data.status}`}>{workshop.data.status}</span>
        <h3 class="mt-3">
          <a href={workshop.data.liveUrl} target="_blank" rel="noopener noreferrer">
            {workshop.data.title}
          </a>
        </h3>
        <p>{workshop.data.tagline}</p>
        <p class="module-progress">{workshop.data.moduleProgress}</p>
        {workshop.data.tags.length > 0 && (
          <ul class="tag-list" aria-label={`Tags for ${workshop.data.title}`}>
            {workshop.data.tags.map((tag) => <li>{tag}</li>)}
          </ul>
        )}
      </article>
    )) : (
      <article class="note-card">
        <p class="note-date">Now</p>
        <h3>Nothing filed yet.</h3>
        <p>The first workshop is still in the shell. Check back soon.</p>
      </article>
    )}
  </div>

  <p class="filter-empty" id="workshop-filter-empty" hidden>
    No workshops match that tag yet — check back as more get added.
  </p>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".tag-filter-btn");
  const cards = document.querySelectorAll<HTMLElement>("#workshop-grid .note-card[data-tags]");
  const emptyState = document.querySelector<HTMLElement>("#workshop-filter-empty");

  function applyFilter(tag: string) {
    let visibleCount = 0;
    cards.forEach((card) => {
      const tags = (card.dataset.tags || "").split(",");
      const match = tag === "all" || tags.includes(tag);
      card.hidden = !match;
      if (match) visibleCount += 1;
    });
    if (emptyState) emptyState.hidden = visibleCount > 0;
  }

  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      buttons.forEach((b) => {
        b.classList.remove("is-active");
        b.setAttribute("aria-pressed", "false");
      });
      button.classList.add("is-active");
      button.setAttribute("aria-pressed", "true");
      applyFilter(button.dataset.tag || "all");
    });
  });
</script>

<style>
  .tag-filter-bar {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin: 0 auto 2.5rem;
    max-width: 48rem;
  }

  .tag-filter-btn {
    border-radius: 999px;
    border: 1px solid theme("colors.kraft / 30%");
    background: theme("colors.parchment");
    color: theme("colors.night / 70%");
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.4rem 0.9rem;
    cursor: pointer;
    transition:
      border-color 0.15s cubic-bezier(0.16, 1, 0.3, 1),
      color 0.15s cubic-bezier(0.16, 1, 0.3, 1),
      background-color 0.15s cubic-bezier(0.16, 1, 0.3, 1);
  }

  :global(.dark) .tag-filter-btn {
    border-color: theme("colors.glow / 25%");
    background: theme("colors.night / 50%");
    color: theme("colors.ivory / 70%");
  }

  .tag-filter-btn:hover,
  .tag-filter-btn:focus-visible {
    border-color: theme("colors.shell");
    color: theme("colors.night");
  }

  :global(.dark) .tag-filter-btn:hover,
  :global(.dark) .tag-filter-btn:focus-visible {
    border-color: theme("colors.glow");
    color: theme("colors.ivory");
  }

  .tag-filter-btn.is-active {
    border-color: theme("colors.shell");
    background: theme("colors.shell / 12%");
    color: theme("colors.night");
  }

  :global(.dark) .tag-filter-btn.is-active {
    border-color: theme("colors.glow");
    background: theme("colors.glow / 12%");
    color: theme("colors.ivory");
  }

  .module-progress {
    margin-top: 0.65rem;
    font-size: 0.8rem;
    line-height: 1.5;
    color: theme("colors.night / 55%");
  }

  :global(.dark) .module-progress {
    color: theme("colors.ivory / 55%");
  }

  .filter-empty {
    margin: 2rem auto 0;
    max-width: 28rem;
    text-align: center;
    color: theme("colors.night / 55%");
    font-size: 0.9rem;
  }

  :global(.dark) .filter-empty {
    color: theme("colors.ivory / 55%");
  }
</style>
