---
import "../styles/global.css";

const base = import.meta.env.BASE_URL;
const url = (path: string) => `${base}${path.replace(/^\//, "")}`;

const nodes = [
  {
    className: "node-hekton",
    label: "Hekton",
    href: url("enter/#ecosystem"),
    detail: "Factory line: scaffolds the job, keeps receipts, and stops clever agents from wandering into load-bearing walls.",
  },
  {
    className: "node-tekton",
    label: "Agentic Tekton",
    href: url("enter/#ecosystem"),
    detail: "Architecture ridge: patterns, operating models, and the grown-up map for agentic systems.",
  },
  {
    className: "node-gremlins",
    label: "Gremlins",
    href: url("enter/#workbench"),
    detail: "Lab spur: reusable product experiments and sharp little tools for the agentic SDLC.",
  },
  {
    className: "node-notes",
    label: "Field notes",
    href: url("blog/"),
    detail: "Workshop trail: the scars, fixes, diagrams, and hard-won notes from the shell.",
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Coderturtle is the practical workshop voice of the Hekton ecosystem: notes, labs, experiments, and field reports from building agentic engineering systems."
    />
    <title>Coderturtle</title>
    <link rel="icon" type="image/x-icon" href={url("favicon.ico")} />
  </head>
  <body class="gateway-body">
    <section class="turtle-gate" aria-labelledby="gate-title">
      <div class="gate-shell-field" aria-label="Coderturtle ecosystem map">
        <span class="shell-ring ring-one" aria-hidden="true"></span>
        <span class="shell-ring ring-two" aria-hidden="true"></span>
        <span class="shell-ring ring-three" aria-hidden="true"></span>
        <span class="shell-trace trace-one" aria-hidden="true"></span>
        <span class="shell-trace trace-two" aria-hidden="true"></span>
        <span class="shell-trace trace-three" aria-hidden="true"></span>
        <span class="shell-trace trace-four" aria-hidden="true"></span>
        <span class="shell-scar scar-one" aria-hidden="true"></span>
        <span class="shell-scar scar-two" aria-hidden="true"></span>
        <span class="shell-scar scar-three" aria-hidden="true"></span>
        {nodes.map((node) => (
          <a
            class={`shell-node ${node.className}`}
            href={node.href}
            data-detail={node.detail}
            aria-label={`${node.label}: ${node.detail}`}
          >
            {node.label}
          </a>
        ))}
      </div>

      <header class="gate-top">
        <a href={url("enter/")} class="gate-brand" aria-label="Enter Coderturtle">
          <img src={url("logo.png")} alt="" width="36" height="36" />
          <span>Coderturtle</span>
        </a>
        <a class="gate-top-link" href={url("blog/")}>Notes</a>
      </header>

      <main class="gate-core">
        <div class="gate-emblem" aria-hidden="true">
          <img src={url("logo-transparent.png")} alt="" class="gate-logo" />
          <span class="emblem-eye"></span>
          <span class="emblem-scar emblem-scar-one"></span>
          <span class="emblem-scar emblem-scar-two"></span>
        </div>
        <p class="gate-eyebrow">battle-scarred notes from the shell</p>
        <h1 id="gate-title">Enter the scarred shell.</h1>
        <p class="gate-tagline">
          Practical notes, lab scars, workshop patterns, and field reports from
          building agentic engineering systems inside the Hekton factory.
        </p>
        <a class="gate-enter" href={url("enter/")}>
          <span>Enter</span>
          <span class="gate-arrow" aria-hidden="true">-&gt;</span>
        </a>
        <p class="gate-hint">
          Hekton is the factory. Agentic Tekton is the architecture layer.
          Coderturtle is the cranky shell at the bench, muttering until the system works.
        </p>
        <p class="gate-readout" id="gate-readout" aria-live="polite">
          Hover the traced ecosystem lines, or just enter the workshop.
        </p>
      </main>

      <footer class="gate-foot">
        <span>Static files, scar tissue, useful experiments.</span>
        <span class="gate-status"><span class="pip"></span> Workshop open</span>
      </footer>
    </section>
    <script>
      const gate = document.querySelector(".turtle-gate");
      const readout = document.querySelector("#gate-readout");
      const nodes = document.querySelectorAll("[data-detail]");
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
      const defaultReadout = "Hover the traced ecosystem lines, or just enter the workshop.";

      function setReadout(value) {
        if (readout) readout.textContent = value;
      }

      if (gate && !reduceMotion.matches) {
        gate.addEventListener("pointermove", (event) => {
          const rect = gate.getBoundingClientRect();
          const x = ((event.clientX - rect.left) / rect.width - 0.5).toFixed(3);
          const y = ((event.clientY - rect.top) / rect.height - 0.5).toFixed(3);
          gate.style.setProperty("--mx", x);
          gate.style.setProperty("--my", y);

          const hovered = document
            .elementFromPoint(event.clientX, event.clientY)
            ?.closest("[data-detail]");
          setReadout(hovered?.dataset.detail || defaultReadout);
        });
      }

      nodes.forEach((node) => {
        node.addEventListener("pointerenter", () => setReadout(node.dataset.detail || ""));
        node.addEventListener("pointerleave", () => setReadout(defaultReadout));
        node.addEventListener("mouseenter", () => setReadout(node.dataset.detail || ""));
        node.addEventListener("focus", () => setReadout(node.dataset.detail || ""));
        node.addEventListener("mouseleave", () => setReadout(defaultReadout));
        node.addEventListener("blur", () => setReadout(defaultReadout));
      });
    </script>
  </body>
</html>

<style>
  :global(body.gateway-body) {
    margin: 0;
    min-height: 100svh;
    background: #1c1c1e;
    color: #f1ecce;
    font-family: Atkinson, Inter, ui-sans-serif, system-ui, sans-serif;
    letter-spacing: 0;
  }

  .turtle-gate {
    --mx: 0;
    --my: 0;
    position: relative;
    width: 100%;
    max-width: 100vw;
    min-height: 100svh;
    overflow: hidden;
    display: grid;
    grid-template-rows: auto 1fr auto;
    isolation: isolate;
    background:
      radial-gradient(circle at calc(50% + (var(--mx) * 7rem)) calc(46% + (var(--my) * 5rem)), rgb(76 149 108 / 0.25), transparent 28rem),
      radial-gradient(circle at calc(74% - (var(--mx) * 5rem)) calc(22% - (var(--my) * 4rem)), rgb(242 92 84 / 0.2), transparent 18rem),
      radial-gradient(circle at calc(30% + (var(--mx) * 4rem)) calc(72% + (var(--my) * 5rem)), rgb(130 184 186 / 0.16), transparent 18rem),
      radial-gradient(circle at 50% 52%, rgb(241 236 206 / 0.08), transparent 19rem),
      linear-gradient(145deg, #171719 0%, #202421 54%, #151616 100%);
  }

  .turtle-gate::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(rgb(241 236 206 / 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgb(241 236 206 / 0.04) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: radial-gradient(circle at center, black 0%, transparent 72%);
  }

  .gate-shell-field {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
    transform: translate(calc(var(--mx) * -12px), calc(var(--my) * -10px));
    transition: transform 0.12s ease-out;
  }

  .gate-shell-field::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    width: min(42rem, 70vw);
    height: min(29rem, 58vh);
    border-radius: 50% 48% 46% 52% / 52% 46% 54% 48%;
    transform: translate(-50%, -50%) rotate(-10deg);
    background:
      linear-gradient(120deg, transparent 0 46%, rgb(241 236 206 / 0.11) 47% 48%, transparent 49%),
      linear-gradient(62deg, transparent 0 44%, rgb(130 184 186 / 0.13) 45% 46%, transparent 47%),
      radial-gradient(circle at 48% 50%, rgb(76 149 108 / 0.2), transparent 60%);
    border: 1px solid rgb(241 236 206 / 0.12);
    box-shadow:
      inset 0 0 60px rgb(76 149 108 / 0.08),
      0 0 90px rgb(130 184 186 / 0.08);
    pointer-events: none;
  }

  .shell-ring {
    position: absolute;
    left: 50%;
    top: 50%;
    border: 1px solid rgb(130 184 186 / 0.22);
    border-radius: 999px;
    transform: translate(-50%, -50%) rotate(-8deg);
    box-shadow: inset 0 0 44px rgb(130 184 186 / 0.04);
    pointer-events: none;
  }

  .ring-one {
    width: min(66rem, 94vw);
    height: min(28rem, 54vh);
    animation: shell-drift 18s ease-in-out infinite;
  }

  .ring-two {
    width: min(48rem, 78vw);
    height: min(20rem, 40vh);
    border-color: rgb(76 149 108 / 0.3);
    transform: translate(-50%, -50%) rotate(9deg);
    animation: shell-drift-alt 22s ease-in-out infinite;
  }

  .ring-three {
    width: min(28rem, 58vw);
    height: min(12rem, 28vh);
    border-color: rgb(242 92 84 / 0.24);
    transform: translate(-50%, -50%) rotate(-18deg);
    animation: shell-drift 16s ease-in-out infinite reverse;
  }

  .shell-trace {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 1px;
    height: min(70rem, 122vh);
    background:
      linear-gradient(to bottom, transparent 0 13%, rgb(130 184 186 / 0.26) 28%, rgb(241 236 206 / 0.2) 50%, rgb(242 92 84 / 0.18) 70%, transparent 87%),
      repeating-linear-gradient(to bottom, transparent 0 18px, rgb(241 236 206 / 0.22) 18px 20px, transparent 20px 34px);
    transform-origin: center;
    pointer-events: none;
    filter: drop-shadow(0 0 12px rgb(130 184 186 / 0.14));
  }

  .trace-one {
    transform: translate(-50%, -50%) rotate(53deg);
  }

  .trace-two {
    transform: translate(-50%, -50%) rotate(116deg);
  }

  .trace-three {
    transform: translate(-50%, -50%) rotate(-24deg);
  }

  .trace-four {
    transform: translate(-50%, -50%) rotate(154deg);
  }

  .shell-scar {
    position: absolute;
    left: 50%;
    top: 50%;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, rgb(242 92 84 / 0.65), rgb(241 236 206 / 0.7), transparent);
    box-shadow: 0 0 16px rgb(242 92 84 / 0.22);
    transform-origin: center;
    pointer-events: none;
  }

  .scar-one {
    width: min(18rem, 34vw);
    transform: translate(-62%, -290%) rotate(-21deg);
  }

  .scar-two {
    width: min(12rem, 24vw);
    transform: translate(10%, 310%) rotate(26deg);
  }

  .scar-three {
    width: min(9rem, 18vw);
    transform: translate(-150%, 140%) rotate(65deg);
  }

  .shell-node {
    position: absolute;
    border: 1px solid rgb(241 236 206 / 0.16);
    border-radius: 8px;
    background: rgb(28 28 30 / 0.72);
    color: rgb(241 236 206 / 0.72);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    padding: 0.55rem 0.7rem;
    text-transform: uppercase;
    text-decoration: none;
    box-shadow: 0 16px 42px rgb(0 0 0 / 0.18);
    backdrop-filter: blur(10px);
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      box-shadow 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
  }

  .shell-node::before {
    content: "";
    display: inline-block;
    width: 0.48rem;
    height: 0.48rem;
    margin-right: 0.5rem;
    border-radius: 50%;
    background: #82b8ba;
    box-shadow: 0 0 0 4px rgb(130 184 186 / 0.12);
  }

  .shell-node:hover,
  .shell-node:focus-visible {
    border-color: #82b8ba;
    background: rgb(130 184 186 / 0.12);
    color: #f1ecce;
    box-shadow: 0 0 42px rgb(130 184 186 / 0.16);
    transform: translate(-50%, -50%) scale(1.05);
  }

  .node-hekton {
    left: calc(50% - min(29rem, 40vw));
    top: calc(50% + min(17rem, 27vh));
  }

  .node-tekton {
    left: calc(50% + min(25rem, 35vw));
    top: calc(50% - min(14rem, 23vh));
  }

  .node-gremlins {
    left: calc(50% + min(27rem, 38vw));
    top: calc(50% + min(17rem, 27vh));
  }

  .node-notes {
    left: calc(50% - min(18rem, 30vw));
    top: calc(50% - min(15rem, 24vh));
  }

  .node-hekton,
  .node-tekton,
  .node-gremlins,
  .node-notes {
    transform: translate(-50%, -50%);
  }

  .gate-top,
  .gate-core,
  .gate-foot {
    position: relative;
    z-index: 2;
  }

  .gate-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem clamp(1rem, 4vw, 3rem);
  }

  .gate-brand,
  .gate-top-link {
    color: inherit;
    text-decoration: none;
  }

  .gate-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-weight: 700;
  }

  .gate-brand img {
    width: 2.25rem;
    height: 2.25rem;
  }

  .gate-top-link {
    border: 1px solid rgb(241 236 206 / 0.18);
    border-radius: 8px;
    padding: 0.65rem 0.85rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    text-transform: uppercase;
  }

  .gate-top-link:hover,
  .gate-top-link:focus-visible,
  .gate-enter:hover,
  .gate-enter:focus-visible {
    border-color: #82b8ba;
    box-shadow: 0 0 32px rgb(130 184 186 / 0.2);
  }

  .gate-core {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1.25rem 1rem;
    pointer-events: none;
  }

  .gate-emblem {
    position: relative;
    width: clamp(5.8rem, 13vw, 8.4rem);
    height: clamp(5.8rem, 13vw, 8.4rem);
    border: 1px solid rgb(130 184 186 / 0.28);
    border-radius: 50% 47% 45% 51% / 50% 45% 55% 48%;
    background:
      radial-gradient(circle at 34% 26%, rgb(241 236 206 / 0.2), transparent 28%),
      linear-gradient(135deg, rgb(76 149 108 / 0.24), rgb(241 236 206 / 0.08));
    padding: 0.8rem;
    box-shadow:
      0 28px 80px rgb(0 0 0 / 0.28),
      inset 0 0 30px rgb(0 0 0 / 0.18);
    transform: translate(calc(var(--mx) * 12px), calc(var(--my) * 10px));
    transition:
      box-shadow 0.2s ease,
      transform 0.12s ease-out;
    pointer-events: auto;
  }

  .gate-emblem:hover {
    box-shadow:
      0 28px 80px rgb(0 0 0 / 0.28),
      0 0 46px rgb(130 184 186 / 0.22),
      inset 0 0 30px rgb(0 0 0 / 0.18);
  }

  .gate-logo {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 8px 16px rgb(0 0 0 / 0.3));
  }

  .emblem-eye {
    position: absolute;
    right: 22%;
    top: 28%;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: #f25c54;
    box-shadow: 0 0 18px rgb(242 92 84 / 0.65);
    z-index: 2;
  }

  .emblem-scar {
    position: absolute;
    height: 2px;
    border-radius: 999px;
    background: #f1ecce;
    opacity: 0.85;
    z-index: 3;
  }

  .emblem-scar-one {
    left: 18%;
    top: 34%;
    width: 42%;
    transform: rotate(-22deg);
  }

  .emblem-scar-two {
    right: 16%;
    bottom: 28%;
    width: 32%;
    transform: rotate(27deg);
  }

  .gate-eyebrow {
    margin: 1rem 0 0;
    color: #f25c54;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .gate-core h1 {
    max-width: 12ch;
    margin: 0.5rem 0 0;
    font-size: clamp(2.8rem, 1.35rem + 6vw, 6.5rem);
    font-weight: 700;
    line-height: 0.94;
  }

  .gate-tagline {
    max-width: 42rem;
    margin: 1rem 0 0;
    color: rgb(241 236 206 / 0.78);
    font-size: clamp(1.05rem, 0.95rem + 0.45vw, 1.3rem);
    line-height: 1.6;
  }

  .gate-enter {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    min-height: 3.25rem;
    margin-top: 1.35rem;
    border: 1px solid #f1ecce;
    border-radius: 999px;
    background: #f1ecce;
    color: #1c1c1e;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-weight: 700;
    padding: 0 1.5rem;
    text-decoration: none;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
    pointer-events: auto;
  }

  .gate-enter:hover,
  .gate-enter:focus-visible {
    transform: translateY(-2px);
  }

  .gate-arrow {
    transition: transform 0.2s ease;
  }

  .gate-enter:hover .gate-arrow {
    transform: translateX(4px);
  }

  .gate-hint {
    max-width: 34rem;
    margin: 1rem 0 0;
    color: rgb(241 236 206 / 0.6);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .gate-readout {
    min-height: 1.5rem;
    max-width: 34rem;
    margin: 0.7rem 0 0;
    color: rgb(130 184 186 / 0.82);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.78rem;
    line-height: 1.5;
  }

  .gate-foot {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.8rem;
    padding: 1.2rem clamp(1rem, 4vw, 3rem);
    color: rgb(241 236 206 / 0.58);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .gate-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .pip {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #82b8ba;
    box-shadow: 0 0 0 0 rgb(130 184 186 / 0.55);
    animation: pulse 2.6s ease-in-out infinite;
  }

  @keyframes pulse {
    50% {
      box-shadow: 0 0 0 7px transparent;
    }
  }

  @keyframes shell-drift {
    50% {
      transform: translate(-50%, -50%) rotate(-3deg) scale(1.025);
    }
  }

  @keyframes shell-drift-alt {
    50% {
      transform: translate(-50%, -50%) rotate(14deg) scale(0.985);
    }
  }

  @media (max-width: 720px) {
    .gate-shell-field {
      opacity: 0.42;
    }

    .shell-node,
    .shell-scar {
      display: none;
    }

    .gate-core h1 {
      max-width: 8ch;
    }

    .gate-foot {
      justify-content: center;
      text-align: center;
    }
  }

  @media (max-height: 760px) and (min-width: 721px) {
    .gate-hint {
      display: none;
    }

    .gate-readout {
      margin-top: 0.8rem;
    }

    .gate-foot {
      padding-top: 0.55rem;
      padding-bottom: 0.55rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pip,
    .gate-enter,
    .gate-arrow,
    .shell-ring,
    .gate-shell-field,
    .gate-emblem {
      animation: none;
      transition: none;
      transform: none;
    }
  }
</style>
