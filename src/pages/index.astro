---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";
import Gear from "../components/marks/Gear.astro";
import Lightbulb from "../components/marks/Lightbulb.astro";
import Compass from "../components/marks/Compass.astro";
import HexBolt from "../components/marks/HexBolt.astro";
import CornerBrackets from "../components/CornerBrackets.astro";

const base = import.meta.env.BASE_URL;
const url = (path: string) => `${base}${path.replace(/^\//, "")}`;

const nodes = [
  {
    label: "Projects",
    href: url("projects/"),
    Mark: Compass,
    detail: "Real builds with an honest log: scars, fixes, and ideas that survived contact with the repo.",
  },
  {
    label: "Workbench",
    href: url("enter/#workbench"),
    Mark: Gear,
    detail: "The workshop where Coderturtle and its agent collaborators build in the open.",
  },
  {
    label: "Labs",
    href: url("enter/#labs"),
    Mark: Lightbulb,
    detail: "Small tests from the workshop, kept honest by logs, screenshots, and a healthy suspicion of demos.",
  },
  {
    label: "The builder",
    href: url("about/"),
    Mark: HexBolt,
    detail: "The cranky turtle at the keyboard: slow shell, sharp questions, and too many production memories.",
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Coderturtle: the gateway to what's next. A futuristic workshop where a cranky engineering turtle and its agent collaborators build in the open."
    />
    <title>Coderturtle</title>
    <link rel="icon" type="image/x-icon" href={url("favicon.ico")} />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("coderturtle-theme");
        const theme = stored ?? "dark";
        document.documentElement.classList.toggle("dark", theme === "dark");
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body class="gateway-body">
    <section class="turtle-gate" aria-labelledby="gate-title">
      <span class="gate-stars" aria-hidden="true"></span>
      <span class="gate-texture" aria-hidden="true"></span>
      <div class="gate-portal-rings" aria-hidden="true">
        <span class="portal-ring ring-1"></span>
        <span class="portal-ring ring-2"></span>
        <span class="portal-ring ring-3"></span>
      </div>
      <div class="gate-marks-field" aria-hidden="true">
        <Gear class="field-mark mark-gear" />
        <Lightbulb class="field-mark mark-bulb" />
        <Compass class="field-mark mark-compass" />
        <HexBolt class="field-mark mark-hex" />
      </div>

      <header class="gate-top">
        <a href={url("enter/")} class="gate-brand" aria-label="Enter Coderturtle">
          <img src={url("logo.png")} alt="" width="36" height="36" />
          <span>Coderturtle</span>
        </a>
        <div class="gate-top-actions">
          <a class="gate-top-link" href={url("projects/")}>Projects</a>
          <ThemeToggle />
        </div>
      </header>

      <main class="gate-core">
        <div class="gate-portrait-stage">
          <button
            class="gate-portrait"
            type="button"
            aria-label="Ask the Coderturtle for a dry engineering note"
            aria-describedby="gate-turtle-quote"
          >
            <img src={url("logo-transparent.png")} alt="A hand-drawn cranky old turtle inventor, arms crossed, wearing round glasses, with a shell tattooed with a lightbulb, a blueprint castle, and a gear." class="gate-portrait-img" />
            <CornerBrackets />
          </button>
          <span class="gate-portrait-id telemetry-label">unit 01 · online</span>
          <p class="gate-turtle-quote" id="gate-turtle-quote" aria-live="polite"></p>
        </div>

        <div class="gate-copy">
          <p class="gate-eyebrow">the gateway to what's next</p>
          <h1 id="gate-title">Coderturtle.</h1>
          <p class="gate-tagline">
            Leading the way into a workshop where a stubborn old engineer and
            its agent collaborators build in the open &mdash; real projects,
            real progress, no highlight reel.
          </p>
          <a class="gate-enter" href={url("enter/")}>
            <span>Enter the future</span>
            <span class="gate-arrow" aria-hidden="true">-&gt;</span>
          </a>
          <nav class="gate-mark-nav" aria-label="Coderturtle workshop paths">
            {nodes.map((node) => {
              const Mark = node.Mark;
              return (
                <a
                  class="gate-mark"
                  href={node.href}
                  data-detail={node.detail}
                  aria-label={`${node.label}: ${node.detail}`}
                >
                  <Mark class="gate-mark-icon" />
                  <span>{node.label}</span>
                </a>
              );
            })}
          </nav>
          <p class="gate-readout" id="gate-readout" aria-live="polite">
            Poke the turtle, or step through a workshop path.
          </p>
        </div>
      </main>

      <footer class="gate-foot">
        <span>Human turtle + agent turtles, building in the open.</span>
        <span class="gate-status"><span class="pip"></span> Systems online</span>
      </footer>
    </section>
    <script>
      const readout = document.querySelector("#gate-readout");
      const nodes = document.querySelectorAll("[data-detail]");
      const portrait = document.querySelector(".gate-portrait");
      const turtleQuote = document.querySelector("#gate-turtle-quote");
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
      const defaultReadout = "Poke the turtle, or step through a workshop path.";
      const turtleQuotes = [
        "It worked in staging because staging has never met a real customer.",
        "The rollback plan is not decorative. Ask me how I know.",
        "If the diagram has no failure path, it is fan fiction.",
        "YAML is just indentation with consequences.",
        "Ship the boring path first. Make it clever after it survives Tuesday.",
        "A shell is just armor with a changelog.",
        "The tool can draft it. The engineer still owns the blast radius.",
      ];
      let quoteIndex = 0;
      let dragStart: { pointerId: number; startX: number; startY: number; originX: number; originY: number; moved: boolean } | null = null;
      let turtleOffset = { x: 0, y: 0 };
      let suppressQuoteClick = false;

      function setReadout(value: string) {
        if (readout) readout.textContent = value;
      }

      function setTurtleTransform(x: number, y: number) {
        turtleOffset = { x, y };
        if (!portrait) return;
        (portrait as HTMLElement).style.setProperty("--turtle-x", `${x}px`);
        (portrait as HTMLElement).style.setProperty("--turtle-y", `${y}px`);
        (portrait as HTMLElement).style.setProperty("--turtle-tilt", `${Math.max(-6, Math.min(6, x / 12))}deg`);
      }

      function setQuote() {
        if (!turtleQuote) return;
        turtleQuote.textContent = turtleQuotes[quoteIndex % turtleQuotes.length];
        turtleQuote.classList.add("has-quote");
        quoteIndex += 1;
      }

      if (portrait) {
        portrait.addEventListener("click", () => {
          if (suppressQuoteClick) {
            suppressQuoteClick = false;
            return;
          }

          setQuote();
        });

        portrait.addEventListener("pointerdown", (event: PointerEvent) => {
          if (reduceMotion.matches || event.button !== 0) return;

          dragStart = {
            pointerId: event.pointerId,
            startX: event.clientX,
            startY: event.clientY,
            originX: turtleOffset.x,
            originY: turtleOffset.y,
            moved: false,
          };
          portrait.classList.add("is-dragging");
          (portrait as HTMLElement).setPointerCapture(event.pointerId);
        });

        portrait.addEventListener("pointermove", (event: PointerEvent) => {
          if (!dragStart || dragStart.pointerId !== event.pointerId) return;

          const nextX = Math.max(-56, Math.min(56, dragStart.originX + event.clientX - dragStart.startX));
          const nextY = Math.max(-40, Math.min(40, dragStart.originY + event.clientY - dragStart.startY));
          dragStart.moved = dragStart.moved || Math.abs(nextX - dragStart.originX) > 4 || Math.abs(nextY - dragStart.originY) > 4;
          setTurtleTransform(nextX, nextY);
        });

        portrait.addEventListener("pointerup", (event: PointerEvent) => {
          if (!dragStart || dragStart.pointerId !== event.pointerId) return;

          suppressQuoteClick = dragStart.moved;
          dragStart = null;
          portrait.classList.remove("is-dragging");
          setTurtleTransform(0, 0);
        });

        portrait.addEventListener("pointercancel", () => {
          dragStart = null;
          suppressQuoteClick = false;
          portrait.classList.remove("is-dragging");
          setTurtleTransform(0, 0);
        });

        portrait.addEventListener("keydown", (event: KeyboardEvent) => {
          const nudge = ({
            ArrowLeft: [-12, 0],
            ArrowRight: [12, 0],
            ArrowUp: [0, -12],
            ArrowDown: [0, 12],
          } as Record<string, [number, number]>)[event.key];

          if (!nudge) return;
          event.preventDefault();
          const nextX = Math.max(-56, Math.min(56, turtleOffset.x + nudge[0]));
          const nextY = Math.max(-40, Math.min(40, turtleOffset.y + nudge[1]));
          setTurtleTransform(nextX, nextY);
        });

        portrait.addEventListener("blur", () => setTurtleTransform(0, 0));
      }

      nodes.forEach((node) => {
        node.addEventListener("pointerenter", () => setReadout((node as HTMLElement).dataset.detail || ""));
        node.addEventListener("pointerleave", () => setReadout(defaultReadout));
        node.addEventListener("mouseenter", () => setReadout((node as HTMLElement).dataset.detail || ""));
        node.addEventListener("focus", () => setReadout((node as HTMLElement).dataset.detail || ""));
        node.addEventListener("mouseleave", () => setReadout(defaultReadout));
        node.addEventListener("blur", () => setReadout(defaultReadout));
      });
    </script>
  </body>
</html>

<style>
  :global(body.gateway-body) {
    margin: 0;
    min-height: 100svh;
    background: #0a0f0d;
    font-family: Atkinson, Inter, ui-sans-serif, system-ui, sans-serif;
    letter-spacing: 0;
  }

  .turtle-gate {
    /* Dark "gateway to the future" is the default, designed experience. */
    --bg: #0a0f0d;
    --bg-soft: #121815;
    --ink: #f1ecce;
    --ink-soft: rgb(241 236 206 / 0.78);
    --ink-faint: rgb(241 236 206 / 0.55);
    --line: rgb(111 221 160 / 0.18);
    --card-bg: rgb(18 24 21 / 0.82);
    --accent: #6fdda0;
    --accent-warm: #c9a56a;
    --accent-loud: #f25c54;
    --mist: #82b8ba;
    position: relative;
    width: 100%;
    max-width: 100vw;
    min-height: 100svh;
    overflow: hidden;
    display: grid;
    grid-template-rows: auto 1fr auto;
    isolation: isolate;
    background:
      radial-gradient(ellipse 70% 50% at 50% 38%, rgb(111 221 160 / 0.12), transparent 62%),
      var(--bg);
    color: var(--ink);
  }

  :global(html:not(.dark)) .turtle-gate {
    --bg: #f7f4ea;
    --bg-soft: #fbf7ec;
    --ink: #1c1c1e;
    --ink-soft: rgb(28 28 30 / 0.7);
    --ink-faint: rgb(28 28 30 / 0.5);
    --line: rgb(28 28 30 / 0.12);
    --card-bg: #ffffff;
    --accent: #4c956c;
    background: var(--bg);
  }

  .gate-stars {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image: radial-gradient(rgb(241 236 206 / 0.5) 1px, transparent 1px);
    background-size: 140px 140px;
    background-position: 20px 30px;
    opacity: 0.35;
  }

  :global(html:not(.dark)) .gate-stars {
    display: none;
  }

  .gate-texture {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image:
      linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 56px 56px;
    opacity: 0.35;
    mask-image: radial-gradient(ellipse 90% 70% at 50% 40%, black 30%, transparent 90%);
  }

  .gate-portal-rings {
    position: absolute;
    left: 50%;
    top: 42%;
    z-index: 0;
    pointer-events: none;
    transform: translate(-50%, -50%);
  }

  .portal-ring {
    position: absolute;
    left: 50%;
    top: 50%;
    border-radius: 999px;
    border: 1px solid rgb(111 221 160 / 0.22);
    transform: translate(-50%, -50%);
    box-shadow: inset 0 0 60px rgb(111 221 160 / 0.05);
  }

  :global(html:not(.dark)) .portal-ring {
    border-color: rgb(76 149 108 / 0.16);
  }

  .ring-1 {
    width: min(30rem, 78vw);
    height: min(30rem, 78vw);
    animation: portal-pulse 9s ease-in-out infinite;
  }

  .ring-2 {
    width: min(42rem, 96vw);
    height: min(42rem, 96vw);
    animation: portal-pulse 9s ease-in-out infinite 1.4s;
  }

  .ring-3 {
    width: min(54rem, 112vw);
    height: min(54rem, 112vw);
    animation: portal-pulse 9s ease-in-out infinite 2.8s;
  }

  .gate-marks-field {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    color: var(--accent-warm);
    opacity: 0.12;
  }

  :global(html.dark) .gate-marks-field {
    color: var(--accent);
    opacity: 0.08;
  }

  .field-mark {
    position: absolute;
    width: 6.5rem;
    height: 6.5rem;
  }

  .mark-gear {
    left: 6%;
    top: 14%;
    transform: rotate(-8deg);
  }

  .mark-bulb {
    right: 8%;
    top: 10%;
    width: 5.25rem;
    height: 5.25rem;
    transform: rotate(6deg);
  }

  .mark-compass {
    left: 10%;
    bottom: 12%;
    width: 5.75rem;
    height: 5.75rem;
    transform: rotate(4deg);
  }

  .mark-hex {
    right: 7%;
    bottom: 16%;
    width: 5rem;
    height: 5rem;
    transform: rotate(-5deg);
  }

  .gate-top,
  .gate-core,
  .gate-foot {
    position: relative;
    z-index: 2;
  }

  .gate-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem clamp(1rem, 4vw, 3rem);
  }

  .gate-brand,
  .gate-top-link {
    color: inherit;
    text-decoration: none;
  }

  .gate-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-weight: 700;
  }

  .gate-brand img {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
  }

  :global(html.dark) .gate-brand img {
    filter: drop-shadow(0 0 8px rgb(111 221 160 / 0.4));
  }

  .gate-top-actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .gate-top-link {
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 0.65rem 0.85rem;
    font-size: 0.85rem;
    font-weight: 700;
  }

  .gate-top-link:hover,
  .gate-top-link:focus-visible {
    border-color: var(--accent);
    color: var(--accent);
  }

  .gate-core {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    align-items: center;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    max-width: 72rem;
    margin: 0 auto;
    padding: 1rem clamp(1rem, 4vw, 3rem) 2rem;
  }

  .gate-portrait-stage {
    position: relative;
    justify-self: center;
    width: 100%;
    max-width: clamp(15rem, 26vw, 21rem);
    animation: turtle-wander 16s ease-in-out infinite;
  }

  .gate-portrait-stage:hover,
  .gate-portrait-stage:focus-within {
    animation-play-state: paused;
  }

  .gate-portrait {
    --turtle-x: 0px;
    --turtle-y: 0px;
    --turtle-tilt: 0deg;
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    border: 1px solid var(--line);
    border-radius: 28px;
    background: var(--card-bg);
    padding: 0.75rem;
    appearance: none;
    cursor: grab;
    box-shadow: 0 24px 48px rgb(0 0 0 / 0.45), 0 0 0 1px rgb(111 221 160 / 0.08);
    transform: translate(var(--turtle-x), var(--turtle-y)) rotate(var(--turtle-tilt));
    transition:
      box-shadow 0.2s ease,
      transform 0.18s cubic-bezier(0.2, 0.8, 0.2, 1);
    touch-action: none;
  }

  :global(html:not(.dark)) .gate-portrait {
    box-shadow: 0 24px 48px rgb(28 28 30 / 0.12);
  }

  .gate-portrait-id {
    display: block;
    margin-top: 0.6rem;
    text-align: center;
  }

  .gate-portrait:hover,
  .gate-portrait:focus-visible,
  .gate-portrait.is-dragging {
    box-shadow: 0 28px 60px rgb(0 0 0 / 0.5), 0 0 44px rgb(111 221 160 / 0.35);
  }

  :global(html:not(.dark)) .gate-portrait:hover,
  :global(html:not(.dark)) .gate-portrait:focus-visible,
  :global(html:not(.dark)) .gate-portrait.is-dragging {
    box-shadow: 0 28px 56px rgb(28 28 30 / 0.16), 0 0 0 4px rgb(76 149 108 / 0.14);
  }

  .gate-portrait:focus-visible {
    outline: 2px solid var(--accent-loud);
    outline-offset: 6px;
  }

  .gate-portrait.is-dragging {
    cursor: grabbing;
    transition: box-shadow 0.2s ease;
  }

  .gate-portrait-img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .gate-turtle-quote {
    position: absolute;
    left: 50%;
    top: 100%;
    z-index: 4;
    width: min(18rem, 92%);
    margin: 0;
    border: 1px solid rgb(242 92 84 / 0.3);
    border-radius: 10px;
    background: var(--card-bg);
    color: var(--ink);
    box-shadow: 0 16px 32px rgb(0 0 0 / 0.4);
    font-size: 0.85rem;
    line-height: 1.5;
    opacity: 0;
    padding: 0.75rem 0.9rem;
    pointer-events: none;
    text-align: left;
    transform: translate(-50%, 0.15rem) rotate(-1deg);
    transition:
      opacity 0.18s ease,
      transform 0.18s ease;
  }

  .gate-turtle-quote::before {
    content: "";
    position: absolute;
    left: 50%;
    top: -0.32rem;
    width: 0.65rem;
    height: 0.65rem;
    border-left: 1px solid rgb(242 92 84 / 0.3);
    border-top: 1px solid rgb(242 92 84 / 0.3);
    background: var(--card-bg);
    transform: translateX(-50%) rotate(45deg);
  }

  .gate-turtle-quote.has-quote {
    opacity: 1;
    transform: translate(-50%, 0.65rem) rotate(-1deg);
  }

  .gate-copy {
    max-width: 34rem;
  }

  .gate-eyebrow {
    margin: 0;
    color: var(--accent);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .gate-copy h1 {
    margin: 0.45rem 0 0;
    font-size: clamp(2.75rem, 1.9rem + 4vw, 5rem);
    font-weight: 700;
    line-height: 0.98;
  }

  :global(html.dark) .gate-copy h1 {
    text-shadow: 0 0 40px rgb(111 221 160 / 0.25);
  }

  .gate-tagline {
    max-width: 32rem;
    margin: 1rem 0 0;
    color: var(--ink-soft);
    font-size: clamp(1rem, 0.95rem + 0.32vw, 1.15rem);
    line-height: 1.55;
  }

  .gate-enter {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    min-height: 3.1rem;
    margin-top: 1.4rem;
    border: 1px solid var(--accent);
    border-radius: 999px;
    background: var(--accent);
    color: #0a0f0d;
    font-weight: 700;
    padding: 0 1.5rem;
    text-decoration: none;
    box-shadow: 0 0 0 rgb(111 221 160 / 0);
    transition:
      border-color 0.15s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.15s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.15s cubic-bezier(0.16, 1, 0.3, 1);
  }

  :global(html:not(.dark)) .gate-enter {
    border-color: var(--ink);
    background: var(--ink);
    color: var(--bg);
  }

  .gate-enter:hover,
  .gate-enter:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 0 32px rgb(111 221 160 / 0.5);
  }

  :global(html:not(.dark)) .gate-enter:hover,
  :global(html:not(.dark)) .gate-enter:focus-visible {
    border-color: var(--accent);
    background: var(--accent);
    box-shadow: none;
  }

  .gate-arrow {
    transition: transform 0.15s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gate-enter:hover .gate-arrow {
    transform: translateX(4px);
  }

  .gate-mark-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    max-width: 34rem;
    margin-top: 1.4rem;
  }

  .gate-mark {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 2.5rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--card-bg);
    color: var(--ink-soft);
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0 0.9rem 0 0.6rem;
    text-decoration: none;
    transition:
      border-color 0.15s cubic-bezier(0.16, 1, 0.3, 1),
      color 0.15s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.15s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.15s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gate-mark-icon {
    width: 1.3rem;
    height: 1.3rem;
    color: var(--accent);
  }

  .gate-mark:hover,
  .gate-mark:focus-visible {
    border-color: var(--accent);
    color: var(--ink);
    transform: translateY(-1px);
  }

  :global(html.dark) .gate-mark:hover,
  :global(html.dark) .gate-mark:focus-visible {
    box-shadow: 0 0 18px rgb(111 221 160 / 0.25);
  }

  .gate-readout {
    min-height: 1.4rem;
    max-width: 32rem;
    margin: 0.9rem 0 0;
    color: var(--ink-faint);
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .gate-foot {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.8rem;
    padding: 1.2rem clamp(1rem, 4vw, 3rem);
    color: var(--ink-faint);
    font-size: 0.78rem;
  }

  .gate-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .pip {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
