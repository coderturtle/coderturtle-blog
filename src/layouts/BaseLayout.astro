---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";

const {
  title = "Coderturtle",
  description = "Hands-on notes from building agentic engineering systems.",
} = Astro.props;

const base = import.meta.env.BASE_URL;
const url = (path: string) => `${base}${path.replace(/^\//, "")}`;
const nav = [
  { href: url("blog/"), label: "Notes" },
  { href: `${url("enter/")}#workbench`, label: "Workbench" },
  { href: `${url("enter/")}#ecosystem`, label: "Ecosystem" },
  { href: url("about/"), label: "About" },
];
const pageTitle = title === "Coderturtle" ? "Coderturtle" : `${title} - Coderturtle`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/x-icon" href={url("favicon.ico")} />
  </head>
  <body>
    <header class="site-header">
      <a href={url("")} class="brand-lockup" aria-label="Coderturtle home">
        <img src={url("logo.png")} alt="" width="32" height="32" />
        <span>Coderturtle</span>
      </a>
      <div class="nav-cluster">
        <nav class="site-nav" aria-label="Primary navigation">
          {nav.map((n) => (
            <a
              href={n.href}
              class:list={[
                !n.href.includes("#") &&
                  Astro.url.pathname === new URL(n.href, Astro.site ?? Astro.url).pathname &&
                  "active",
              ]}
            >
              {n.label}
            </a>
          ))}
        </nav>
        <ThemeToggle />
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <p>Built by Coderturtle. Powered by Astro, static files, and stubborn curiosity.</p>
      <p>Shipping slow, debugging fast.</p>
    </footer>
  </body>
</html>
